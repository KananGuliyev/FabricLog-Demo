# FabricLog public demo environment
# No secrets are required for the public portfolio version.
# The app uses mock data and mock authentication only.

# Optional:
# NODE_ENV affects cookie security flags in the mock auth flow.
# Leave this unset for local development; production hosts set it automatically.
# NODE_ENV=development

# Optional:
# Public base URL for canonical metadata, robots, and sitemap generation.
# Recommended for deployment platforms like Vercel if you want explicit
# canonical/share URLs instead of the built-in localhost fallback.
# SITE_URL=https://your-demo-domain.com
